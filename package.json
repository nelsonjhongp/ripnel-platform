{
  "name": "ripnel-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "next": "^16.2.4"
  },
  "scripts": {
    "dev:backend": "npm run dev --workspace @ripnel/backend",
    "dev:frontend": "npm run dev --workspace @ripnel/frontend",
    "start:backend": "npm run start --workspace @ripnel/backend",
    "lint:frontend": "npm run lint --workspace @ripnel/frontend",
    "typecheck": "npm run typecheck --workspace @ripnel/frontend",
    "test:backend": "npm run test --workspace @ripnel/backend",
    "test:frontend": "npm run test --workspace @ripnel/frontend"
  }
}
