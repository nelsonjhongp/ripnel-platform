# Backend environment variables
# Copy to .env  and fill with real values for your environment.

# Server
PORT=3001
NODE_ENV=development

# Database (Supabase connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Database SSL
# Set DB_SSL=false only for local Postgres without SSL.
# In Supabase, leave defaults (SSL on, cert validated against system store).
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
# Optional: path to a CA certificate file for self-signed or custom CAs.
# CA_CERT_PATH=

# JWT
JWT_SECRET=change-me-to-a-32-char-minimum-random-string

# Frontend URL (for CORS + CSRF origin gate)
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated extra allowed origins (supports *.host wildcards)
# ALLOWED_ORIGINS=https://app.ripnel.com,https://*.ripnel-preview.com

# Session cookie domain (optional, leave empty for localhost)
SESSION_COOKIE_DOMAIN=

# Google Gemini (chatbot)
GEMINI_API_KEY=

# SMTP (email receipts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=