# RIPNEL backend — plantilla de variables de entorno para STAGING
#
# ADVERTENCIA: este archivo es solo una plantilla con placeholders.
# NO copiar valores reales aqui ni commitear ningun archivo derivado
# de este con valores reales. El .env real vive unicamente en el
# Droplet de staging, fuera del repositorio (ya cubierto por
# .gitignore: .env / .env.* salvo los *.example).
#
# Ver docs/working/reports/INFRA-04-B-staging-runbook.md secciones 5 y 9.

PORT=3001
NODE_ENV=production
DATABASE_URL=<STAGING_DATABASE_URL_WITH_SSL>
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
CA_CERT_PATH=<OPTIONAL_PATH_TO_DO_CA_CERT_OUTSIDE_REPO>
JWT_SECRET=<GENERATE_STAGING_JWT_SECRET_OUTSIDE_REPO>
FRONTEND_URL=https://<STAGING_DOMAIN>
SESSION_COOKIE_DOMAIN=
GEMINI_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
